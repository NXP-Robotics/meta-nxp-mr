From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Benjamin Perseghetti <bperseghetti@rudislabs.com>
Date: Wed, 15 Jan 2025 00:00:00 +0000
Subject: [PATCH] xnnpack: Update kleidiai SHA256 hash after fetch

GitLab regenerated the archive for kleidiai commit 847ebd1, changing the
SHA256 hash. This patch fixes the hash in XNNPACK DownloadKleidiAI.cmake
after XNNPACK is fetched but before it is configured.

Upstream-Status: Pending [gitlab archive regeneration issue]

Signed-off-by: Benjamin Perseghetti <bperseghetti@rudislabs.com>
---
 litertgit/tflite/tools/cmake/modules/xnnpack.cmake | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/litertgit/tflite/tools/cmake/modules/xnnpack.cmake b/litertgit/tflite/tools/cmake/modules/xnnpack.cmake
index 1111111..2222222 100644
--- a/litertgit/tflite/tools/cmake/modules/xnnpack.cmake
+++ b/litertgit/tflite/tools/cmake/modules/xnnpack.cmake
@@ -33,6 +33,16 @@ if(NOT xnnpack_POPULATED)
   OverridableFetchContent_Populate(xnnpack)
 endif()
 
+# Fix kleidiai SHA256 hash - GitLab regenerated the archive
+set(KLEIDIAI_CMAKE_FILE "${CMAKE_BINARY_DIR}/xnnpack/cmake/DownloadKleidiAI.cmake")
+if(EXISTS ${KLEIDIAI_CMAKE_FILE})
+  file(READ ${KLEIDIAI_CMAKE_FILE} KLEIDIAI_CMAKE_CONTENT)
+  string(REPLACE "f3ea4fce53f3b31076958dbff229f0048dae15bf454929673c78292a56279d52"
+                 "3564707756473a165ddb3cf670187a4eeb2189c71c5ef01e865567cab071daac"
+                 KLEIDIAI_CMAKE_CONTENT "${KLEIDIAI_CMAKE_CONTENT}")
+  file(WRITE ${KLEIDIAI_CMAKE_FILE} "${KLEIDIAI_CMAKE_CONTENT}")
+endif()
+
 # May consider setting XNNPACK_USE_SYSTEM_LIBS if we want to control all
 # dependencies by TFLite.
 set(XNNPACK_BUILD_TESTS OFF CACHE BOOL "Disable XNNPACK test.")
