From 1086cb04055dbe65c4c62ed259134e395aa09b5d Mon Sep 17 00:00:00 2001
From: Peter van der Perk <peter.vanderperk@nxp.com>
Date: Fri, 19 Jun 2026 11:19:42 +0200
Subject: [PATCH] arm64: dts: imx95-navqb: enable P3H hub TP2 as GPIO

Rename the P3H i3c-hub target-port 2 node from "smbus@2" to "gpio@2" so the
p3h2840 hub driver configures TP2 in GPIO mode and registers a gpiochip for
its SCL/SDA pins.

Upstream-Status: Pending

Signed-off-by: Peter van der Perk <peter.vanderperk@nxp.com>
---
 arch/arm64/boot/dts/freescale/imx95-navqb.dts | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/freescale/imx95-navqb.dts b/arch/arm64/boot/dts/freescale/imx95-navqb.dts
index 4a6d918abc8f..4da168b64188 100644
--- a/arch/arm64/boot/dts/freescale/imx95-navqb.dts
+++ b/arch/arm64/boot/dts/freescale/imx95-navqb.dts
@@ -566,7 +566,7 @@ imx219_mipi_0_ep: endpoint {
 			};
 		};
 
-		p3h_gpio: smbus@2 {
+		p3h_gpio: gpio@2 {
 			reg = <0x2>;
 			#address-cells = <1>;
 			#size-cells = <0>;
-- 
2.34.1

