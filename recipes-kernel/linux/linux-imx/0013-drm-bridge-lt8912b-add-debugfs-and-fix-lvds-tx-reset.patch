From 42e4275f9c0468c8db1a505de1c40317a719811a Mon Sep 17 00:00:00 2001
From: Peter van der Perk <peter.vanderperk@nxp.com>
Date: Tue, 23 Jun 2026 14:03:12 +0200
Subject: [PATCH] drm/bridge: lt8912b: add debugfs and attempt to fix init sequence
Attempt to Fix for stable HDMI output on boards without a hardware RESET GPIO:

1. Remove {0x03, 0xcf} LVDS TX module reset from write_lvds_config.
   This reset holds SDA low on the I2C bus, blocking all subsequent
   transactions on the P3H hub SMBus port.

2. Add DDS reset {0x05, 0xfb->0xff} in write_rxlogicres_config for
   stable MIPI PLL lock (from ESP/Olimex reference driver).

3. Fix settle register (CEC_DSI 0x11): use 0x10 for all resolutions
   >= 720p, matching the ESP reference (upstream used 0x0a/0x08).

4. Increase DDS reset hold time to 10ms (from 1ms) to match ESP.

5. Wait for MIPI DSI input to be stable before issuing the MIPI RX
   reset. Poll MAIN reg 0x9c (MIPI hsync counter) before the reset —
   not after, as the reset clears the counter. This prevents the chip
   from failing to lock when DSI HS output hasn't started yet.

6. Fix soft_power_on to propagate write errors and not mark the chip
   as powered on if CEC_DSI writes fail (e.g. due to a transient SDA
   stuck at probe time on the P3H hub). bridge_enable now retries
   soft_power_on so the CEC_DSI lane/config registers are correctly
   programmed when the bus is stable.

7. Add bring-up debugfs interface:
     status: read key registers (power state, mipi_stat, HPD, etc.)
     poke:   write/read individual registers by client+address

Upstream-Status: Pending

Signed-off-by: Peter van der Perk <peter.vanderperk@nxp.com>
---
 drivers/gpu/drm/bridge/lontium-lt8912b.c | 168 +++++++++++++++++++++--
 1 file changed, 160 insertions(+), 8 deletions(-)

diff --git a/drivers/gpu/drm/bridge/lontium-lt8912b.c b/drivers/gpu/drm/bridge/lontium-lt8912b.c
index 35110b542298..9118ea640c80 100644
--- a/drivers/gpu/drm/bridge/lontium-lt8912b.c
+++ b/drivers/gpu/drm/bridge/lontium-lt8912b.c
@@ -7,6 +7,8 @@
 #include <linux/delay.h>
 #include <linux/gpio/consumer.h>
 #include <linux/i2c.h>
+#include <linux/debugfs.h>
+#include <linux/seq_file.h>
 #include <linux/media-bus-format.h>
 #include <linux/regmap.h>
 
@@ -47,6 +49,7 @@ struct lt8912 {
 
 	u8 data_lanes;
 	bool is_power_on;
+	struct dentry *debugfs;
 };
 
 static int lt8912_write_init_config(struct lt8912 *lt)
@@ -163,6 +166,11 @@ static int lt8912_write_rxlogicres_config(struct lt8912 *lt)
 	usleep_range(10000, 20000);
 	ret |= regmap_write(lt->regmap[I2C_MAIN], 0x03, 0xff);
 
+	/* DDS reset — required for stable MIPI PLL lock (from ESP reference) */
+	ret |= regmap_write(lt->regmap[I2C_MAIN], 0x05, 0xfb);
+	usleep_range(10000, 20000);
+	ret |= regmap_write(lt->regmap[I2C_MAIN], 0x05, 0xff);
+
 	return ret;
 };
 
@@ -193,8 +201,8 @@ static int lt8912_write_lvds_config(struct lt8912 *lt)
 
 		{0x02, 0xf7}, // lvds pll reset
 		{0x02, 0xff},
-		{0x03, 0xcf},
-		{0x03, 0xff},
+		/* {0x03, 0xcf} LVDS TX module reset intentionally omitted:
+		 * causes chip to hold SDA low, blocking the I2C bus. */
 	};
 
 	return regmap_multi_reg_write(lt->regmap[I2C_MAIN], seq, ARRAY_SIZE(seq));
@@ -307,8 +315,8 @@ static int lt8912_video_setup(struct lt8912 *lt)
 
 	if (vactive <= 600)
 		settle = 0x04;
-	else if (vactive == 1080)
-		settle = 0x0a;
+	else
+		settle = 0x10; /* per LT8912B ESP reference driver */
 
 	ret = regmap_write(lt->regmap[I2C_CEC_DSI], 0x10, 0x01);
 	ret |= regmap_write(lt->regmap[I2C_CEC_DSI], 0x11, settle);
@@ -351,11 +359,19 @@ static int lt8912_soft_power_on(struct lt8912 *lt)
 {
 	if (!lt->is_power_on) {
 		u32 lanes = lt->data_lanes;
+		int ret;
+
+		ret = lt8912_write_init_config(lt);
+		if (ret)
+			return ret;
 
-		lt8912_write_init_config(lt);
-		regmap_write(lt->regmap[I2C_CEC_DSI], 0x13, lanes & 3);
+		ret = regmap_write(lt->regmap[I2C_CEC_DSI], 0x13, lanes & 3);
+		if (ret)
+			return ret;
 
-		lt8912_write_mipi_basic_config(lt);
+		ret = lt8912_write_mipi_basic_config(lt);
+		if (ret)
+			return ret;
 
 		lt->is_power_on = true;
 	}
@@ -365,7 +381,7 @@ static int lt8912_soft_power_on(struct lt8912 *lt)
 
 static int lt8912_video_on(struct lt8912 *lt)
 {
-	int ret;
+	int ret, i;
 
 	ret = lt8912_video_setup(lt);
 	if (ret < 0)
@@ -375,6 +391,27 @@ static int lt8912_video_on(struct lt8912 *lt)
 	if (ret < 0)
 		goto end;
 
+	/*
+	 * Wait for MIPI DSI input to be stable before resetting the MIPI RX.
+	 * The iMX95 DSI needs a few frames after encoder enable before it
+	 * produces HS data. MAIN reg 0x9c holds a rolling MIPI hsync counter —
+	 * non-zero means DSI is streaming HS data. Check BEFORE the RX reset
+	 * so the reset itself doesn't clear the counter (ESP detect_input_mipi
+	 * does the same check before mipi_rx_logic_reset).
+	 * Up to 10 attempts × 20ms = 200ms max wait.
+	 */
+	for (i = 0; i < 10; i++) {
+		unsigned int hsync = 0;
+
+		if (regmap_read(lt->regmap[I2C_MAIN], 0x9c, &hsync) == 0 && hsync != 0) {
+			dev_dbg(lt->dev, "MIPI input stable (attempt %d, hsync=0x%02x)\n",
+				i + 1, hsync);
+			break;
+		}
+		dev_dbg(lt->dev, "MIPI not yet stable (attempt %d), waiting\n", i + 1);
+		msleep(20);
+	}
+
 	ret = lt8912_write_rxlogicres_config(lt);
 	if (ret < 0)
 		goto end;
@@ -461,6 +498,15 @@ static void lt8912_bridge_mode_set(struct drm_bridge *bridge,
 static void lt8912_bridge_enable(struct drm_bridge *bridge)
 {
 	struct lt8912 *lt = bridge_to_lt8912(bridge);
+	int ret;
+
+	/* Retry soft_power_on in case CEC_DSI writes failed during attach
+	 * due to a transiently stuck SDA at probe time. */
+	ret = lt8912_soft_power_on(lt);
+	if (ret) {
+		dev_err(lt->dev, "enable: soft_power_on failed: %d\n", ret);
+		return;
+	}
 
 	lt8912_video_on(lt);
 }
@@ -569,6 +615,18 @@ static int lt8912_bridge_attach(struct drm_bridge *bridge,
 	if (ret)
 		return ret;
 
+	/* Probe chip presence — soft_power_on will log clearly if ENXIO */
+	{
+		unsigned int val;
+		int probe_ret = regmap_read(lt->regmap[I2C_MAIN], 0x00, &val);
+
+		if (probe_ret == 0)
+			dev_info(lt->dev, "chip present: reg0=0x%02x\n", val);
+		else
+			dev_warn(lt->dev, "chip not responding (ret=%d) — check RESETN/power\n",
+				 probe_ret);
+	}
+
 	ret = lt8912_soft_power_on(lt);
 	if (ret)
 		goto error;
@@ -756,6 +814,96 @@ static int lt8912_put_dt(struct lt8912 *lt)
 	return 0;
 }
 
+/* debugfs: live register access for HDMI bring-up (chip sits behind the P3H hub) */
+static const struct {
+	u8 client;
+	u8 reg;
+	const char *name;
+} lt8912_dbg_regs[] = {
+	{ I2C_MAIN,    0x00, "main_00"   },
+	{ I2C_MAIN,    0x01, "main_01"   },
+	{ I2C_MAIN,    0x08, "clk_en"    },  /* digital clock enables */
+	{ I2C_MAIN,    0x44, "hdmi_pll"  },  /* HDMI PLL analog */
+	{ I2C_MAIN,    0xb2, "hdmi_mode" },  /* HDMI/LVDS mode select */
+	{ I2C_MAIN,    0xc1, "hpd_cable" },  /* HPD/cable detect */
+	{ I2C_MAIN,    0xab, "sync_pol"  },
+	{ I2C_CEC_DSI, 0x12, "dsi_cfg"   },  /* DSI config */
+	{ I2C_CEC_DSI, 0x13, "dsi_lanes" },
+	{ I2C_CEC_DSI, 0x9b, "mipi_stat" },  /* MIPI PHY status */
+};
+
+static int lt8912_status_show(struct seq_file *s, void *unused)
+{
+	struct lt8912 *lt = s->private;
+	unsigned int v;
+	int i, ret;
+
+	seq_printf(s, "is_power_on=%d data_lanes=%u\n",
+		   lt->is_power_on, lt->data_lanes);
+
+	for (i = 0; i < ARRAY_SIZE(lt8912_dbg_regs); i++) {
+		ret = regmap_read(lt->regmap[lt8912_dbg_regs[i].client],
+				  lt8912_dbg_regs[i].reg, &v);
+		if (ret)
+			seq_printf(s, "%-10s [%d:0x%02x] = ERR %d\n",
+				   lt8912_dbg_regs[i].name,
+				   lt8912_dbg_regs[i].client,
+				   lt8912_dbg_regs[i].reg, ret);
+		else
+			seq_printf(s, "%-10s [%d:0x%02x] = 0x%02x\n",
+				   lt8912_dbg_regs[i].name,
+				   lt8912_dbg_regs[i].client,
+				   lt8912_dbg_regs[i].reg, v);
+	}
+	return 0;
+}
+DEFINE_SHOW_ATTRIBUTE(lt8912_status);
+
+/* "<client> <reg> [val]": write val, or read when val is omitted (result in dmesg) */
+static ssize_t lt8912_poke_write(struct file *f, const char __user *ubuf,
+				 size_t len, loff_t *off)
+{
+	struct lt8912 *lt = file_inode(f)->i_private;
+	unsigned int client, reg, val;
+	char buf[32];
+	int n, ret;
+
+	if (len >= sizeof(buf))
+		return -EINVAL;
+	if (copy_from_user(buf, ubuf, len))
+		return -EFAULT;
+	buf[len] = '\0';
+
+	n = sscanf(buf, "%i %i %i", &client, &reg, &val);
+	if (n < 2 || client >= I2C_MAX_IDX || reg > 0xff)
+		return -EINVAL;
+
+	if (n >= 3) {
+		ret = regmap_write(lt->regmap[client], reg, val);
+		dev_info(lt->dev, "poke W [%u:0x%02x] = 0x%02x -> %d\n",
+			 client, reg, val, ret);
+	} else {
+		ret = regmap_read(lt->regmap[client], reg, &val);
+		dev_info(lt->dev, "poke R [%u:0x%02x] = 0x%02x (ret %d)\n",
+			 client, reg, ret ? 0 : val, ret);
+	}
+	return ret ? ret : len;
+}
+
+static const struct file_operations lt8912_poke_fops = {
+	.owner = THIS_MODULE,
+	.open = simple_open,
+	.write = lt8912_poke_write,
+	.llseek = default_llseek,
+};
+
+static void lt8912_debugfs_init(struct lt8912 *lt)
+{
+	lt->debugfs = debugfs_create_dir(dev_name(lt->dev), NULL);
+	debugfs_create_file("status", 0444, lt->debugfs, lt, &lt8912_status_fops);
+	debugfs_create_file("poke",   0200, lt->debugfs, lt, &lt8912_poke_fops);
+}
+
 static int lt8912_probe(struct i2c_client *client)
 {
 	static struct lt8912 *lt;
@@ -780,6 +928,8 @@ static int lt8912_probe(struct i2c_client *client)
 
 	i2c_set_clientdata(client, lt);
 
+	lt8912_debugfs_init(lt);
+
 	lt->bridge.of_node = dev->of_node;
 	lt->bridge.ops = (DRM_BRIDGE_OP_EDID |
 			  DRM_BRIDGE_OP_DETECT);
@@ -793,6 +943,7 @@ static int lt8912_probe(struct i2c_client *client)
 	return 0;
 
 err_attach:
+	debugfs_remove_recursive(lt->debugfs);
 	drm_bridge_remove(&lt->bridge);
 	lt8912_free_i2c(lt);
 err_i2c:
@@ -805,6 +956,7 @@ static void lt8912_remove(struct i2c_client *client)
 {
 	struct lt8912 *lt = i2c_get_clientdata(client);
 
+	debugfs_remove_recursive(lt->debugfs);
 	drm_bridge_remove(&lt->bridge);
 	lt8912_free_i2c(lt);
 	lt8912_put_dt(lt);
-- 
2.34.1

