From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Peter van der Perk <peter.vanderperk@nxp.com>
Date: Fri, 19 Jun 2026 15:47:53 +0200
Subject: [PATCH] i3c: hub: p3h2840: chunk large SMBus reads to fit controller
 buffer

The 84-byte controller buffer is shared by the write offset and the read
data, so an offset-write + >84-byte read (a 128-byte EDID block) overruns
it: the tail reads back as zeros, corrupting the EDID so DRM finds no
modes ("Cannot find any crtc or sizes").

Split such reads into <=(84 - offset) chunks, bumping the offset each
time like an EEPROM read. Everything else keeps the single-shot path.

Upstream-Status: Pending

Signed-off-by: Peter van der Perk <peter.vanderperk@nxp.com>
---
 drivers/i3c/hub/p3h2840_i3c_hub_smbus.c | 130 ++++++++++++++----------
 1 file changed, 77 insertions(+), 53 deletions(-)

diff --git a/drivers/i3c/hub/p3h2840_i3c_hub_smbus.c b/drivers/i3c/hub/p3h2840_i3c_hub_smbus.c
index 199216553fcb..2fa0731181df 100644
--- a/drivers/i3c/hub/p3h2840_i3c_hub_smbus.c
+++ b/drivers/i3c/hub/p3h2840_i3c_hub_smbus.c
@@ -183,44 +183,20 @@ static int p3h2x4x_read_smbus_transaction_status(struct p3h2x4x_i3c_hub_dev *hub
 	}
 }
 
-/*
- * p3h2x4x_tp_i2c_xfer_msg() - This starts a SMBus write transaction by writing a descriptor
- * and a message to the p3h2x4x registers. Controller buffer page is determined by multiplying the
- * target port index by four and adding the base page number to it.
- */
-static int p3h2x4x_tp_i2c_xfer_msg(struct p3h2x4x_i3c_hub_dev *p3h2x4x_i3c_hub,
-				   struct i2c_msg *xfers,
-				   u8 target_port,
-				   u8 nxfers_i, u8 rw)
+/* One SMBus transaction; wlen + rlen must fit P3H2X4X_SMBUS_PAYLOAD_SIZE. */
+static int p3h2x4x_tp_smbus_one(struct p3h2x4x_i3c_hub_dev *p3h2x4x_i3c_hub,
+				u8 target_port, u8 rw_address, u8 type,
+				const u8 *wbuf, u8 wlen, u8 *rbuf, u8 rlen)
 {
 	u8 controller_buffer_page = P3H2X4X_CONTROLLER_BUFFER_PAGE + 4 * target_port;
 	u8 target_port_status = P3H2X4X_TP0_SMBUS_AGNT_STS + target_port;
 	u8 desc[P3H2X4X_SMBUS_DESCRIPTOR_SIZE] = { 0 };
-	u8 transaction_type = P3H2X4X_SMBUS_400KHZ;
-	int write_length, read_length;
-	u8 addr = xfers[nxfers_i].addr;
-	u8 rw_address = 2 * addr;
 	int ret, ret2;
 
-	if (rw == 2) { /* write and read */
-		write_length = xfers[nxfers_i].len;
-		read_length =  xfers[nxfers_i + 1].len;
-	} else if (rw == 1) {
-		rw_address |= P3H2X4X_SET_BIT(0);
-		write_length = 0;
-		read_length =  xfers[nxfers_i].len;
-	} else {
-		write_length = xfers[nxfers_i].len;
-		read_length = 0;
-	}
-
 	desc[P3H2X4X_DESC_ADDR] = rw_address;
-	if (rw == 2)
-		desc[P3H2X4X_DESC_TYPE] = transaction_type | P3H2X4X_SET_BIT(0);
-	else
-		desc[P3H2X4X_DESC_TYPE] = transaction_type;
-	desc[P3H2X4X_DESC_WRITE_LEN] = write_length;
-	desc[P3H2X4X_DESC_READ_LEN] = read_length;
+	desc[P3H2X4X_DESC_TYPE] = type;
+	desc[P3H2X4X_DESC_WRITE_LEN] = wlen;
+	desc[P3H2X4X_DESC_READ_LEN] = rlen;
 
 	ret = regmap_write(p3h2x4x_i3c_hub->regmap, target_port_status,
 			   P3H2X4X_TP_BUFFER_STATUS_MASK);
@@ -228,53 +204,101 @@ static int p3h2x4x_tp_i2c_xfer_msg(struct p3h2x4x_i3c_hub_dev *p3h2x4x_i3c_hub,
 		goto out;
 
 	ret = regmap_write(p3h2x4x_i3c_hub->regmap, P3H2X4X_PAGE_PTR, controller_buffer_page);
-
 	if (ret)
 		goto out;
 
 	ret = regmap_bulk_write(p3h2x4x_i3c_hub->regmap, P3H2X4X_CONTROLLER_AGENT_BUFF,
 				desc, P3H2X4X_SMBUS_DESCRIPTOR_SIZE);
-
 	if (ret)
 		goto out;
 
-	if (!(rw % 2)) {
+	if (wlen) {
 		ret = regmap_bulk_write(p3h2x4x_i3c_hub->regmap,
-					P3H2X4X_CONTROLLER_AGENT_BUFF_DATA,
-					xfers[nxfers_i].buf, xfers[nxfers_i].len);
+					P3H2X4X_CONTROLLER_AGENT_BUFF_DATA, wbuf, wlen);
 		if (ret)
 			goto out;
 	}
 
 	ret = regmap_write(p3h2x4x_i3c_hub->regmap, P3H2X4X_TP_SMBUS_AGNT_TRANS_START,
 			   p3h2x4x_i3c_hub->tp_bus[target_port].tp_mask);
-
 	if (ret)
 		goto out;
 
 	ret = p3h2x4x_read_smbus_transaction_status(p3h2x4x_i3c_hub,
-						    target_port_status,
-						    (write_length + read_length));
+						    target_port_status, wlen + rlen);
 	if (ret)
 		goto out;
 
-	if (rw) {
-		if (rw == 2)
-			nxfers_i += 1;
-
+	if (rlen)
 		ret = regmap_bulk_read(p3h2x4x_i3c_hub->regmap,
-				       P3H2X4X_CONTROLLER_AGENT_BUFF_DATA + write_length,
-				       xfers[nxfers_i].buf, xfers[nxfers_i].len);
-		if (ret)
-			goto out;
-	}
+				       P3H2X4X_CONTROLLER_AGENT_BUFF_DATA + wlen,
+				       rbuf, rlen);
 out:
-	ret2 = regmap_write(p3h2x4x_i3c_hub->regmap,
-			    P3H2X4X_PAGE_PTR, 0x00);
-	if (!ret && ret2)
-		ret = ret2;
+	ret2 = regmap_write(p3h2x4x_i3c_hub->regmap, P3H2X4X_PAGE_PTR, 0x00);
+	return ret ? ret : ret2;
+}
 
-	return ret;
+/* Offset-write + read that overflows the buffer is split into EEPROM-style chunks. */
+static int p3h2x4x_tp_i2c_xfer_msg(struct p3h2x4x_i3c_hub_dev *p3h2x4x_i3c_hub,
+				   struct i2c_msg *xfers,
+				   u8 target_port,
+				   u8 nxfers_i, u8 rw)
+{
+	u8 transaction_type = P3H2X4X_SMBUS_400KHZ;
+	u8 addr = xfers[nxfers_i].addr;
+	u8 rw_address = 2 * addr;
+	const u8 *wbuf = NULL;
+	u8 *rbuf = NULL;
+	int write_length, read_length;
+
+	if (rw == 2) { /* write and read */
+		transaction_type |= P3H2X4X_SET_BIT(0);
+		write_length = xfers[nxfers_i].len;
+		wbuf = xfers[nxfers_i].buf;
+		read_length = xfers[nxfers_i + 1].len;
+		rbuf = xfers[nxfers_i + 1].buf;
+	} else if (rw == 1) {
+		rw_address |= P3H2X4X_SET_BIT(0);
+		write_length = 0;
+		read_length = xfers[nxfers_i].len;
+		rbuf = xfers[nxfers_i].buf;
+	} else {
+		write_length = xfers[nxfers_i].len;
+		wbuf = xfers[nxfers_i].buf;
+		read_length = 0;
+	}
+
+	if (rw == 2 && write_length && write_length <= sizeof(u32) &&
+	    read_length > P3H2X4X_SMBUS_PAYLOAD_SIZE - write_length) {
+		u8 max_chunk = P3H2X4X_SMBUS_PAYLOAD_SIZE - write_length;
+		u8 ptr[sizeof(u32)];
+		u32 offset = 0;
+		int i, done = 0, ret;
+
+		for (i = 0; i < write_length; i++)
+			offset = (offset << 8) | wbuf[i];
+
+		while (done < read_length) {
+			u8 chunk = min_t(int, read_length - done, max_chunk);
+
+			for (i = 0; i < write_length; i++)
+				ptr[i] = offset >> (8 * (write_length - 1 - i));
+
+			ret = p3h2x4x_tp_smbus_one(p3h2x4x_i3c_hub, target_port,
+						   rw_address, transaction_type,
+						   ptr, write_length, rbuf + done, chunk);
+			if (ret)
+				return ret;
+
+			done += chunk;
+			offset += chunk;
+		}
+		return 0;
+	}
+
+	return p3h2x4x_tp_smbus_one(p3h2x4x_i3c_hub, target_port, rw_address,
+				    transaction_type, wbuf, write_length,
+				    rbuf, read_length);
 }
 
 /*
