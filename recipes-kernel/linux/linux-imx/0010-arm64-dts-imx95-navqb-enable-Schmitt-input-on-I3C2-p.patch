From a79f9492a230c54356eb3c77490f77397c9dafdc Mon Sep 17 00:00:00 2001
From: Peter van der Perk <peter.vanderperk@nxp.com>
Date: Fri, 19 Jun 2026 12:29:25 +0200
Subject: [PATCH] arm64: dts: imx95-navqb: enable Schmitt input on I3C2 pads

Enable the Schmitt-trigger input (HYS) on the I3C2 SCL/SDA pads
(ENET1_MDC/MDIO). The open-drain I3C bus to the P3H hub is glitch-prone
during IBI arbitration; a brief SDA high->low->high glitch is latched by
the Silvaco controller as a target start, which then fails IBIWON
arbitration and floods the log with "Timeout when polling for IBIWON".
Adding input hysteresis rejects these glitches and removes the idle IBIWON
background.

Upstream-Status: Pending

Signed-off-by: Peter van der Perk <peter.vanderperk@nxp.com>
---
 arch/arm64/boot/dts/freescale/imx95-navqb.dts | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/freescale/imx95-navqb.dts b/arch/arm64/boot/dts/freescale/imx95-navqb.dts
index 4da168b64188..3eb37e6915e0 100644
--- a/arch/arm64/boot/dts/freescale/imx95-navqb.dts
+++ b/arch/arm64/boot/dts/freescale/imx95-navqb.dts
@@ -945,8 +945,8 @@ isi_in_2: endpoint {
 &scmi_iomuxc {
 	pinctrl_i3c2: i3c2grp {
 		fsl,pins = <
-			IMX95_PAD_ENET1_MDC__I3C2_SCL			0x40000106
-			IMX95_PAD_ENET1_MDIO__I3C2_SDA			0x40000106
+			IMX95_PAD_ENET1_MDC__I3C2_SCL			0x40001106
+			IMX95_PAD_ENET1_MDIO__I3C2_SDA			0x40001106
 		>;
 	};
 
