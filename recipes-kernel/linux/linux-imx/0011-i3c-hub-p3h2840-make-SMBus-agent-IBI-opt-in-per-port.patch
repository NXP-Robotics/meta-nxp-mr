From a733dbe4a0a24195a18ba86c9ccc637c4e271139 Mon Sep 17 00:00:00 2001
From: Peter van der Perk <peter.vanderperk@nxp.com>
Date: Fri, 19 Jun 2026 13:32:13 +0200
Subject: [PATCH] i3c: hub: p3h2840: make SMBus agent IBI opt-in per port

Agent IBI (reg 0x1b) is only needed when a downstream device is the bus
master (MCTP); host-initiated transfers complete by status polling.

Force-enabling it on every declared SMBus port makes unused/floating
ports latch phantom RX events and raise IBIs the controller can't
service -> "Timeout when polling for IBIWON", relatched and repeated.

Gate it on a new per-port "nxp,smbus-agent-ibi" property. Default off:
reg 0x1b stays 0, the timeouts stop.

Upstream-Status: Pending

Signed-off-by: Peter van der Perk <peter.vanderperk@nxp.com>
---
 drivers/i3c/hub/p3h2840_i3c_hub_smbus.c | 19 +++++++++++++++++--
 1 file changed, 17 insertions(+), 2 deletions(-)

diff --git a/drivers/i3c/hub/p3h2840_i3c_hub_smbus.c b/drivers/i3c/hub/p3h2840_i3c_hub_smbus.c
index 5a2d6e27098b..adb3cc9773d8 100644
--- a/drivers/i3c/hub/p3h2840_i3c_hub_smbus.c
+++ b/drivers/i3c/hub/p3h2840_i3c_hub_smbus.c
@@ -4,6 +4,7 @@
  * This P3H2X4X driver file contain functions for SMBus/I2C virtual Bus creation and read/write.
  */
 #include <linux/mfd/p3h2840.h>
+#include <linux/of.h>
 #include <linux/regmap.h>
 
 #include "p3h2840_i3c_hub.h"
@@ -612,9 +613,17 @@ int p3h2x4x_tp_smbus_algo(struct p3h2x4x_i3c_hub_dev *hub)
 			return ret;
 		}
 
-		ibi_mask |= hub->tp_bus[tp].tp_mask;
+		/*
+		 * Agent IBI is only for downstream bus-master / MCTP ports.
+		 * On unused/floating ports it self-triggers, surfacing as the
+		 * controller's "Timeout when polling for IBIWON". Opt in.
+		 */
+		if (of_property_read_bool(hub->tp_bus[tp].of_node,
+					  "nxp,smbus-agent-ibi")) {
+			ibi_mask |= hub->tp_bus[tp].tp_mask;
+			hub->hub_config.tp_config[tp].ibi_en = true;
+		}
 		hub->tp_bus[tp].is_registered = true;
-		hub->hub_config.tp_config[tp].ibi_en = true;
 		hub->tp_bus[tp].tp_smbus_adapter = smbus_adapter;
 	}
 
