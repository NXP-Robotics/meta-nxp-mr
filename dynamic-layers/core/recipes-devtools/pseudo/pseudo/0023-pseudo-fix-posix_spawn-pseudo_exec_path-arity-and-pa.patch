From 05eb6d6e76068fe54462e8a2c16ced231ff9781c Mon Sep 17 00:00:00 2001
From: Peter van der Perk <peter.vanderperk@nxp.com>
Date: Fri, 12 Jun 2026 12:33:13 +0200
Subject: [PATCH] pseudo: fix posix_spawn* pseudo_exec_path arity and
 patternlistmatchespath local-addr return

Two compile errors with pseudo 1.9.2 + NXP chroot patches:

1. ports/common/guts/posix_spawn.c and posix_spawnp.c call
   pseudo_exec_path() with 2 args (old signature) but NXP patch 0011
   changed it to 3 args (const char **filenamep, int, char * const**argvp).
   Update posix_spawn*.c to use the new 3-arg call pattern.

2. pseudo_client.c:patternlistmatchespath() (added by NXP fnmatch patch)
   returns the address of the local 'patternbuf' variable when no external
   resbuf is provided. Use a static sentinel string instead for callers
   that only use the return value as boolean (NULL / non-NULL).

Signed-off-by: Copilot <223556219+Copilot@users.noreply.github.com>
---
 ports/common/guts/posix_spawn.c  |  2 +-
 ports/common/guts/posix_spawnp.c |  2 +-
 pseudo_client.c                  | 13 +++++++++++--
 3 files changed, 13 insertions(+), 4 deletions(-)

diff --git a/ports/common/guts/posix_spawn.c b/ports/common/guts/posix_spawn.c
index e15e68f..d00eb27 100644
--- a/ports/common/guts/posix_spawn.c
+++ b/ports/common/guts/posix_spawn.c
@@ -15,7 +15,7 @@
 	 * design will likely be revisited.
 	 */
         if (antimagic == 0) {
-		const char *path_guess = pseudo_exec_path(path, 0);
+		const char *path_guess = pseudo_exec_path(&path, 0, (char * const **)&argv);
                 pseudo_client_op(OP_EXEC, PSA_EXEC, -1, -1, path_guess, 0);
         }
 
diff --git a/ports/common/guts/posix_spawnp.c b/ports/common/guts/posix_spawnp.c
index b2e1fc8..7956794 100644
--- a/ports/common/guts/posix_spawnp.c
+++ b/ports/common/guts/posix_spawnp.c
@@ -15,7 +15,7 @@
 	 * design will likely be revisited.
 	 */
         if (antimagic == 0) {
-		const char *path_guess = pseudo_exec_path(file, 1);
+		const char *path_guess = pseudo_exec_path(&file, 1, (char * const **)&argv);
                 pseudo_client_op(OP_EXEC, PSA_EXEC, -1, -1, path_guess, 0);
         }
 
diff --git a/pseudo_client.c b/pseudo_client.c
index 6448c12..82cc1dd 100644
--- a/pseudo_client.c
+++ b/pseudo_client.c
@@ -1514,6 +1514,8 @@ pseudo_client_shutdown(int wait_on_socket) {
 static char *patternlistmatchespath(const char *patternlist, const char *path, char *resbuf, size_t resbuflen, int checkalias)
 {
 	char *foundpath = NULL, *res;
+	/* static sentinel for callers that only need boolean result (NULL/non-NULL) */
+	static char matched_sentinel[] = "";
 
 	/* For backwards compatibility, no patternlist means that
 	 * anything matches. THis is different from an empty list!
@@ -1522,8 +1524,9 @@ static char *patternlistmatchespath(const char *patternlist, const char *path, c
 		char patternbuf[NAME_MAX];
 		const char *s = patternlist;
 		size_t i,j;
+		int use_local_buf = !resbuf;
 
-		if (!resbuf) {
+		if (use_local_buf) {
 			resbuf = &patternbuf[0];
 			resbuflen = sizeof(patternbuf);
 		}
@@ -1545,7 +1548,13 @@ static char *patternlistmatchespath(const char *patternlist, const char *path, c
 						res = NULL;
 				}
 				if(fnmatch(resbuf, path, 0) == 0) {
-					foundpath = res;
+					/* If we used a local buffer, return a
+					 * static sentinel instead of the
+					 * local-variable address. Callers that
+					 * need the matched value must pass
+					 * an external resbuf.
+					 */
+					foundpath = use_local_buf ? matched_sentinel : res;
 					break;
 				}
 			}
-- 
2.34.1

