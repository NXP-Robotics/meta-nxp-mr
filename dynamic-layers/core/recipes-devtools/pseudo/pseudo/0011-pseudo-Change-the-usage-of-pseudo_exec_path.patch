-	 */
-	sigprocmask(SIG_SETMASK, &pseudo_saved_sigmask, NULL);
-	rc = real_execvp(file, argv);
+    if (path_guess) {
+        pseudo_setupenv();
+        if (pseudo_has_unload(NULL))
