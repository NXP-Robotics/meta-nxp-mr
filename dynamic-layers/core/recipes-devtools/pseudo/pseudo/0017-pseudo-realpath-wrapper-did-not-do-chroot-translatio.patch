From 5b136da09008479c89631a18ca97ee4e94b36f2d Mon Sep 17 00:00:00 2001
From: Peter van der Perk <peter.vanderperk@nxp.com>
Date: Fri, 12 Jun 2026 12:24:02 +0200
Subject: [PATCH 17/22] pseudo: realpath wrapper did not do chroot translation

---
 ports/unix/guts/realpath.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/ports/unix/guts/realpath.c b/ports/unix/guts/realpath.c
index 8d8118b..df5bbf6 100644
--- a/ports/unix/guts/realpath.c
+++ b/ports/unix/guts/realpath.c
@@ -21,7 +21,9 @@
 			*(ep--) = '\0';
 		}
 
-		if (len >= pseudo_sys_path_max()) {
+	len = pseudo_dechroot(rname, len);
+
+	if (len >= pseudo_sys_path_max()) {
 		errno = ENAMETOOLONG;
 		return NULL;
 	}
-- 
2.34.1

