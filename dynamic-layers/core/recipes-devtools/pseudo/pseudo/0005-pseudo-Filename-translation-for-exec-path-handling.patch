From f290114692e3c123e2afea66526ee9638f3cf3d4 Mon Sep 17 00:00:00 2001
From: Peter van der Perk <peter.vanderperk@nxp.com>
Date: Fri, 12 Jun 2026 12:24:02 +0200
Subject: [PATCH 05/22] pseudo: Filename translation for exec path handling

---
 pseudo_client.c | 12 ++++++++++++
 pseudo_util.c   |  1 +
 2 files changed, 13 insertions(+)

diff --git a/pseudo_client.c b/pseudo_client.c
index a8ef267..9c32a15 100644
--- a/pseudo_client.c
+++ b/pseudo_client.c
@@ -2246,6 +2246,8 @@ pseudo_exec_path(const char *filename, int search_path) {
 	char *candidate;
 	int i;
 	struct stat buf;
+	char aliasbuf[NAME_MAX];
+	char *xtranslation = getenv("PSEUDO_CHROOT_XTRANSLATION");
 
 	if (!filename)
 		return NULL;
@@ -2262,6 +2264,16 @@ pseudo_exec_path(const char *filename, int search_path) {
 		populate_path_segs();
 	}
 
+	/* We check a precise path translation first and fall back to
+	 * the base name only. This permits generic aliasing of basenames
+	 */
+	s = patternlistmatchespath(xtranslation, filename, &aliasbuf[0], sizeof(aliasbuf), 1);
+	if (!s)
+		s = patternlistmatchespath(xtranslation, basename(filename), &aliasbuf[0], sizeof(aliasbuf), 1);
+	if (s) {
+		filename = s;
+	}
+
 	/* absolute paths just get canonicalized. */
 	if (*filename == '/') {
 		candidate = pseudo_fix_path(NULL, filename, 0, 0, NULL, 0);
diff --git a/pseudo_util.c b/pseudo_util.c
index a94a4da..9d8a185 100644
--- a/pseudo_util.c
+++ b/pseudo_util.c
@@ -47,6 +47,7 @@ static struct pseudo_variables pseudo_env[] = {
 	{ "PSEUDO_IGNORE_PATHS", 19, NULL },
 	{ "PSEUDO_PASSWD", 13, NULL },
 	{ "PSEUDO_CHROOT", 13, NULL },
+	{ "PSEUDO_CHROOT_XTRANSLATION", 26, NULL },
 	{ "PSEUDO_UIDS", 11, NULL },
 	{ "PSEUDO_GIDS", 11, NULL },
 	{ "PSEUDO_OPTS", 11, NULL },
